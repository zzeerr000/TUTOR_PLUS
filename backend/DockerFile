# Используем официальный образ Node.js
FROM node:20-alpine

# Устанавливаем рабочую директорию
WORKDIR /app

# Копируем файлы управления зависимостями
COPY package*.json ./

# Устанавливаем все зависимости (включая dev для сборки)
RUN npm install

# Копируем исходный код
COPY . .

# Собираем приложение
RUN npm run build

# Удаляем dev зависимости после сборки для оптимизации
RUN npm prune --production

# Создаем пользователя без прав root для безопасности
RUN addgroup -g 1001 -S nodejs
RUN adduser -S nodejs -u 1001

# Меняем владельца файлов
RUN chown -R nodejs:nodejs /app

# Переключаемся на пользователя nodejs
USER nodejs

# Создаем директории для загрузок от имени пользователя nodejs
RUN mkdir -p uploads/avatars uploads/homework

# Открываем порт
EXPOSE 3000

# Переменные окружения
ENV NODE_ENV=production

# Запускаем приложение
CMD ["npm", "run", "start:prod"]