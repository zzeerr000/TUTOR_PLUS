# Zoom SDK Credentials (for Meeting SDK)
ZOOM_SDK_KEY=your_zoom_sdk_key
ZOOM_SDK_SECRET=your_zoom_sdk_secret

# Zoom OAuth Credentials (for API calls and meeting creation)
# Use a "User-managed OAuth" app from Zoom App Marketplace
ZOOM_CLIENT_ID=your_zoom_client_id
ZOOM_CLIENT_SECRET=your_zoom_client_secret
ZOOM_REDIRECT_URI=http://localhost:3000/zoom/callback

# Server configuration
PORT=3000
DATABASE_URL=tutorplus.db
JWT_SECRET=your_jwt_secret
FRONTEND_URL=http://localhost:5173
